#!/usr/bin/env python3
#
# Updates docker/docker-prod.json with current base image versions.
#
# Alpine: 6 latest releases (~3 years at 6-month cadence)
# Debian: 3 latest releases (~4-6 years)
#
# Queries endoflife.date API for version data.
# Run periodically or before releases to keep base image versions current.

import json
import logging
import urllib.request
from pathlib import Path

ENDOFLIFE_ALPINE_URL = "https://endoflife.date/api/alpine-linux.json"
ENDOFLIFE_DEBIAN_URL = "https://endoflife.date/api/debian.json"

ALPINE_COUNT = 6
DEBIAN_COUNT = 3


def fetch_versions(url: str, count: int) -> list[str]:
    with urllib.request.urlopen(url, timeout=10) as resp:
        data = json.loads(resp.read())
    return [entry["cycle"] for entry in data[:count]]


def main() -> None:
    logging.basicConfig(level=logging.INFO, format="%(message)s")

    script_dir = Path(__file__).resolve().parent
    config_path = script_dir.parent / "docker" / "docker-prod.json"

    alpine = fetch_versions(ENDOFLIFE_ALPINE_URL, ALPINE_COUNT)
    debian = fetch_versions(ENDOFLIFE_DEBIAN_URL, DEBIAN_COUNT)

    logging.info("Alpine: %s", ", ".join(alpine))
    logging.info("Debian: %s", ", ".join(debian))

    config = {
        "bases": {
            "alpine": alpine,
            "debian": debian,
            "scratch": [],
        }
    }

    with config_path.open("w") as f:
        json.dump(config, f, indent=2)
        f.write("\n")

    logging.info("Updated %s", config_path)


if __name__ == "__main__":
    main()
